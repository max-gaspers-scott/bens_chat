# Backend runtime configuration
DATABASE_URL=postgres://dbuser:p@localhost:1111/data
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=data

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password

# MinIO Public Endpoint (browser-accessible).
# For local dev: localhost:9000
# For production (behind Cloudflare Tunnel): s3.yourdomain.com
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Set to "true" if the public endpoint is HTTPS (Cloudflare Tunnel)
MINIO_SECURE=false

# Required in production: use a long random secret
JWT_SECRET=replace-with-a-long-random-secret

# Optional JWT lifetime in hours (defaults to 24 if unset)
JWT_EXP_HOURS=24

# Allowed browser origins for cross-origin requests.
# For a single-host deployment behind Cloudflare/Caddy/Nginx, set this to your stable public app URL.
CORS_ALLOWED_ORIGINS=https://chat.yourdomain.com

# Frontend note:
# - For same-origin production deploys, do NOT set REACT_APP_API_URL; the frontend will use relative URLs.
# - For local CRA dev against the backend on localhost:9821, no env var is needed.
# - Only set REACT_APP_API_URL if you intentionally want the frontend to call a different public API origin.
# REACT_APP_API_URL=https://api.yourdomain.com